# Copy this file to .env and fill in your API_KEY.
# .env is gitignored; .env.example is committed as a template.

API_BASE_URL=http://localhost:8000/v1
API_KEY=REPLACE_WITH_YOUR_KEY
MODEL_ID=Qwen3.5-27B-Claude-4.6-Opus-Distilled-MLX-4bit

TRANSLATOR_PORT=8101
REVIEWER_PORT=8102
SUMMARIZER_PORT=8103

# Shared bearer token for agent-to-agent calls.
# Comment out (or unset) to disable auth (agents become open).
AGENT_TOKEN=REPLACE_WITH_A_LONG_RANDOM_STRING
