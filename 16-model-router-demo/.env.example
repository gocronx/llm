# Copy this file to .env and fill in your API_KEY.
# .env is gitignored; .env.example is committed as a template.

API_BASE_URL=http://localhost:8000/v1
API_KEY=REPLACE_WITH_YOUR_KEY

# Three tiers of model — set to whatever IDs your endpoint serves.
# All three can be the same model if you only have one (demo still runs).
MODEL_CHEAP=GLM-4.7-Flash-4bit
MODEL_MID=Qwen3.5-27B-Claude-4.6-Opus-Distilled-MLX-4bit
MODEL_PREMIUM=Qwen3.6-40B-Claude-4.6-Opus-Deckard-Heretic-Uncensored-Thinking-8bit
